
<style>
  /* Règles pour le titre animé */
  #titre {
    font-family: 'Noto Sans', sans-serif;
    font-size: 15vh;
    font-weight: 800;

    /* image servie depuis public/uploads -> chemin public: /uploads/nom.jpg */
    background: url('/uploads/violet.jpg') center / 300% no-repeat;

    /* clipper le background sur le texte */
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;

    /* standard fallback */
    background-clip: text;
    color: transparent;

    /* animation du background-position */
    animation: bgMove 12s linear infinite;
  }

  /* animation : on déplace la position x du background */
  @keyframes bgMove {
    0%   { background-position:   0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position:   0% 50%; }
  }
</style>

